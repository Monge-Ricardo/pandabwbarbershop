# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, this is usually personal config.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used with a pyproject.toml, the lock file should be gitignored.
# Pipfile.lock

# poetry
#   Poetry uses pyproject.toml to manage dependencies and is recommended to commit poetry.lock.
#   https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-file-to-version-control
# poetry.lock

# pdm
#   PDM stores project-wide configurations in .pdm-python and recommends to gitignore it.
#   https://pdm.fming.dev/latest/usage/project/#gitignore
.pdm-python
.pdm-build/

# pipx
.pipx/

